{%- extends "./base.njk" -%} {%- block content -%}

<div id="main-content" class="main-content">
  <div class="container p-t-md">
    <main class="main-primary" id="main">
      <nav aria-label="You are here" class="breadcrumbs">
        <ol>
          <li>
            <a href="/index.html" title="Home page">Home</a>
          </li>
          <li>Samples</li>
          <li>{{title | title}}</li>
        </ol>
      </nav>
      <div class="row">
        <div class="col-lg-3 pe-lg-5" role="complementary">
          <!-- Side navigation -->
          <details class="side-navigation-toggle" aria-label="Toggle side navigation" aria-expanded="false"
  aria-controls="side-navigation-content">
            <summary>
              <span class="container d-block">Side navigation</span>
            </summary>
          </details>
          <div class="container" id="side-navigation-content">
            <nav aria-label="Side navigation" class="side-navigation sticky-6">
              <ul class="list-navigation">
                {%- for entry in collections.all | allSamples %}
                <li>
                  <a
                    href="{{ entry.url }}"
                    class="{{ 'landing active' if entry.url == page.url }}"
                    {{ 'aria-current="page"' if entry.url == page.url }}>
                    {{- entry.data.title | title -}}
                  </a>
                </li>
                {%- endfor %}
              </ul>
            </nav>
          </div>
        </div>
        <div class="col-lg-9 p-b-lg">
          <h1 class="mt-lg-0">{{ title | title }}</h1>
          <!-- BEGIN SAMPLE CONTENT -->
          {{ content | SampleCodeUseMainSiteImages | safe }}
          <!-- END SAMPLE CONTENT -->
        </div>
      </div>
    </main>
  </div>
</div>
{%- endblock -%}
